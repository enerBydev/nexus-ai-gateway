#!/bin/sh
# Pre-push hook for validation before pushing to remote
# Only runs full validation for main branch pushes
#
# Checks:
# 1. Version sync across VERSION, Cargo.toml, src/lib.rs
# 2. Tag exists for current version (reminder)
# 3. cargo test
# 4. cargo clippy
# 5. cargo audit (if installed)

remote="$1"
url="$2"

# Read the ref being pushed
while read local_ref local_sha remote_ref remote_sha; do
# Only validate pushes to main
if [ "$remote_ref" = "refs/heads/main" ]; then
	echo "🔍 Validating before push to main..."
	echo ""

	# 1. Version sync check (M1)
	V_FILE=$(cat VERSION 2>/dev/null)
	V_CARGO=$(grep '^version' Cargo.toml | sed 's/version = "\(.*\)"/\1/')
	V_LIB=$(grep 'pub const VERSION' src/lib.rs 2>/dev/null | sed 's/.*"\(.*\)".*/\1/')

	if [ "$V_FILE" != "$V_CARGO" ] || [ "$V_FILE" != "$V_LIB" ]; then
		echo "❌ Version mismatch detected!"
		echo "   VERSION file: $V_FILE"
		echo "   Cargo.toml:   $V_CARGO"
		echo "   src/lib.rs:   $V_LIB"
		echo ""
		echo "   Run: task bump-patch (or bump-minor/bump-major)"
		exit 1
	fi
	echo " ✅ Version sync: $V_FILE"

	# 2. Tag validation (M1)
	TAG="v$V_FILE"
	if ! git rev-parse "$TAG" >/dev/null 2>&1; then
		echo " ⚠️  No git tag for $TAG — consider running: task release"
	else
		echo " ✅ Tag $TAG exists"
	fi

	# 3. Run tests
	echo ""
	echo " Running cargo test..."
	if ! cargo test --quiet 2>/dev/null; then
		echo "❌ Tests failed! Push blocked."
		exit 1
	fi
	echo " ✅ Tests passed"

	# 4. Run clippy
	echo " Running cargo clippy..."
	if ! cargo clippy -- -D warnings 2>/dev/null; then
		echo "❌ Clippy errors found! Push blocked."
		exit 1
	fi
	echo " ✅ Clippy passed"

	# 5. Security audit (M3) — non-blocking if cargo-audit not installed
	if command -v cargo-audit >/dev/null 2>&1; then
		echo " Running cargo audit..."
		if ! cargo audit --quiet 2>/dev/null; then
			echo "⚠️ Security vulnerabilities found! Review with: cargo audit"
			echo "   (Not blocking push — fix when possible)"
		else
			echo " ✅ Security audit passed"
		fi
	fi

	echo ""
	echo "✅ Pre-push validation passed"

	# ═══════════════════════════════════════════════════════
	# Auto-deploy: build and install release binary
	# For gh pr merge / UI merge sync, git-sync daemon handles automatically
	# Post-push auto-sync is below (Layer 2 of 3-layer sync system)
	# ═══════════════════════════════════════════════════════
	(
		# Wait for push to complete
		sleep 3

		echo ""
		echo "🔄 Auto-deploy: building release binary..."
		if cargo build --release 2>&1 | tail -3; then
			BINARY="target/release/nexus-ai-gateway"
			if [ -f "$BINARY" ]; then
				# Install to both locations with proper permissions
				install -m 0755 "$BINARY" "$HOME/.cargo/bin/nexus-ai-gateway"
				install -m 0755 "$BINARY" "$HOME/.local/bin/nexus-ai-gateway"

				# Verify with MD5
				ORIGINAL_MD5=$(md5sum "$BINARY" | cut -d' ' -f1)
				CARGO_MD5=$(md5sum "$HOME/.cargo/bin/nexus-ai-gateway" | cut -d' ' -f1)
				LOCAL_MD5=$(md5sum "$HOME/.local/bin/nexus-ai-gateway" | cut -d' ' -f1)

				if [ "$ORIGINAL_MD5" = "$CARGO_MD5" ] && [ "$ORIGINAL_MD5" = "$LOCAL_MD5" ]; then
					echo "✅ Binary installed and verified (~/.cargo/bin and ~/.local/bin)"
				else
					echo "⚠️  MD5 mismatch — binary may be corrupted"
				fi

				# Restart systemd service
				systemctl --user restart nexus-ai-gateway.service
				sleep 2

				# Health check
				if curl -sf http://localhost:8315/health >/dev/null 2>&1; then
					echo "✅ Service restarted and healthy (port 8315)"
				else
					echo "⚠️  Service may have failed to start — check: systemctl --user status nexus-ai-gateway"
				fi
			else
				echo "❌ Binary not found after build"
			fi
		else
			echo "❌ Build failed — service NOT updated (previous binary still running)"
		fi
	) &

	# ═══════════════════════════════════════════════════════
	# Auto-sync: pull CI version bump commit after push
	# This is Layer 2 of the 3-layer autonomous sync system.
	# Layer 1 (git-sync daemon) provides backup coverage.
	# ═══════════════════════════════════════════════════════
	(
		echo ""
		echo "⏳ Auto-sync: waiting for CI auto-version commit..."
		MAX_RETRIES=6
		RETRY_INTERVAL=60
		SYNCED=false

		for i in $(seq 1 $MAX_RETRIES); do
			sleep $RETRY_INTERVAL
			if git pull --ff-only origin main 2>/dev/null; then
				NEW_VER=$(cat VERSION 2>/dev/null | tr -d '[:space:]')
				echo "✅ Auto-sync: local updated to v${NEW_VER} (attempt $i/$MAX_RETRIES)"

				# Trigger post-merge hook for rebuild
				if [ -x scripts/hooks/post-merge ]; then
					scripts/hooks/post-merge
				fi
				SYNCED=true
				break
			fi
		done

		if [ "$SYNCED" = false ]; then
			echo "ℹ️ Auto-sync: no version bump after $((MAX_RETRIES * RETRY_INTERVAL))s"
			echo "  Git-sync daemon will handle this automatically"
		fi
	) &
fi
done

exit 0
